rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}/history/{date}
    // Document ID: date (YYYY-MM-DD)
    // Fields:
    //   - date: string (required, format: date)
    //   - morningInput: map (optional)
    //   - morningOutput: string (optional)
    //   - noNegociables: list (optional)
    //   - cognitiveChecklist: map (required)
    //   - nightInput: string (optional)
    //   - nightOutput: string (optional)
    //   - score: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "carlos.llerena.theshedco@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidDailyData(data) {
      return data.date is string &&
             data.cognitiveChecklist is map &&
             (!('score' in data) || (data.score is number && data.score >= 0 && data.score <= 100)) &&
             (!('noNegociables' in data) || data.noNegociables is list);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();

      match /history/{date} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if (isOwner(userId) || isAdmin()) && isValidDailyData(request.resource.data);
        allow delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
